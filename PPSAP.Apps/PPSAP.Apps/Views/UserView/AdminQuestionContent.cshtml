@model PPSAP.Common.QuestionDetails
@{
    Layout = null;
}

<div class="col-lg-12 tab-section" style="padding-left: 65px;padding-right: 70px;">
    <ul class="nav nav-tabs responsive-tabs" role="tablist">
        <li role="presentation" class="active"><a href="#discussion" aria-controls="discussion" role="tab" data-toggle="tab">Discussion</a></li>
       @* <li role="presentation"><a href="#bcsc-excerpt" aria-controls="bcsc-excerpt" role="tab" data-toggle="tab">BCSC Excerpt</a></li>*@
        <li role="presentation"><a href="#references" aria-controls="references" role="tab" data-toggle="tab">References</a></li>
        <li role="presentation"><a href="#notes" aria-controls="notes" role="tab" data-toggle="tab">Notes</a></li>
    </ul>
    <div class="tab-content" id="TabContentId">
        <div role="tabpanel" class="tab-pane active padtop20" id="discussion">
            <div class="col-lg-12">

                @* <p>Proin elit arcu, rutrum commodo, vehicula tempus, commodo a, risus. Curabitur nec arcu. Donec sollicitudin mi sit amet mauris. Nam elementum quam ullamcorper ante. Etiam aliquet massa et lorem. Mauris dapibus lacus auctor risus. Aenean tempor ullamcorper leo. Vivamus sed magna quis ligula eleifend adipiscing. Duis orci. Aliquam sodales tortor vitae ipsum. Aliquam nulla. Duis aliquam molestie erat. Ut et mauris vel pede varius sollicitudin. Sed ut dolor nec orci tincidunt interdum. Phasellus ipsum. Nunc tristique tempus lectus.</p>*@
                @if (!string.IsNullOrEmpty(@Model.questionDiscussion.discussionText))
                {
                    <p>@Html.Raw(@Model.questionDiscussion.discussionText)</p>
                }
                @if (@Model.questionDiscussion.discussionImage != null)
                {
                    foreach (var image in @Model.questionDiscussion.discussionImage)
                    {
                        @*<img src="@Url.Content(image.ImagePath)" alt="Image" style="width:2%!important" />*@
                        <div class="col-lg-12 nopadding">

                            <div class="col-sm-2 col-xs-6 nopadding mar10">
                                <a href="@Url.Content(image.ImagePath)" class="thumbnail" data-toggle="modal" data-target="#myModal" data-image="@Url.Content(image.ImagePath)">
                                    <img src="@Url.Content(image.ImagePath)" id="5525" alt="Image" class="img-responsive img-center img11">
                                    <div class="zoom-icon-background text-right myDIV">
                                        <i class="glyphicon glyphicon-zoom-in text-right">
                                        </i>
                                    </div>
                                </a>
                            </div>
                        </div>
                        @*<p>&nbsp;</p>*@
                        <div class="clearfix"></div>
                    }
                }
            </div>
        </div>


        <div role="tabpanel" class="tab-pane padtop20" id="references">
            <div class="col-lg-12">
                @foreach (var reference in @Model.references)
                {
                    <p>@Html.Raw(@reference)</p>
                }
            </div>
        </div>
        <div role="tabpanel" class="tab-pane padtop20" id="notes">
            <div class="col-lg-12">
                @foreach (string notes in @Model.notes)
                {
                    <p>@Html.Raw(@notes)</p>
                }

            </div>
        </div>
    </div>
</div>
<div class="clearfix">
</div>
