@model List<PPSAP.Common.OptInReports>
@{
    ViewBag.Title = "Terms & Conditions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/moment.min.js"></script>
<link href="~/Content/admin.css" rel="stylesheet" />

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12">
            <ul class="breadcrumb"><li class="active">Terms & Conditions</li></ul>
        </div>
    </div>
</div>

<div class="col-lg-12">
    <div class="content-bg">
        <div class="content-padding">
            <div class="col-lg-6 col-sm-5 xs-textcenter nopadding">
                <label class="active">Admin Application T&C Reports</label>
            </div>
            <div class="col-lg-6 dropdown grey-font font18 pull-right text-right nopadding xs-textcenter">
                <div class="inline-block">
                    @*<select id="Year" name="optionsval" class="form-control form-control-sm" style="padding-top: 0px;" disabled>
                        <option value="-1" disabled selected hidden>All</option>
                    </select>*@
                </div>
                <div class="inline-block">
                    <input type="button" value="Export" id="Export" class="btn btn-primary marleft10 btn-export">
                </div>
            </div>
            <div class="clearfix"></div>
            <div class="col-lg-12 nopadding table-responsive">
                <table border="0" width="100%">
                    <tr>
                        <td style="width:70%">
                            <table class="table table-striped" id="OptInReport" style="overflow-x:hidden; border:1px solid #000">
                                <thead>
                                    <tr>
                                        <td style="text-align: left;">User ID</td>
                                        <td style="text-align: left;">User Name</td>
                                        <td @*style="text-align: center;"*@>Status</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    @*@foreach(var user in Model ) {
                            <tr>
                                <td>@user.UserId </td>
                                <td>@user.UserName</td>
                                <td>@user. </td>
                            </tr>
                            }*@
                                </tbody>
                            </table>
                        </td>

                        <td style="width:2%"></td>

                        <td style="width:20%; padding-top:10px;" valign="top">
                            <table border="1" width="100%">
                                <tr id="OptInReport_UserCount">
                                    <td colspan="2">User Count</td>
                                </tr>
                                <tr>
                                    <td width="55%">Total User:</td>
                                    <td id="TotalUserCount" style="text-align: center;"></td>
                                </tr>
                                <tr>
                                    <td width="55%">Accepted User:</td>
                                    <td id="TotalAcceptedUserCount" style="text-align: center;"></td>
                                </tr>
                                <tr>
                                    <td width="55%">Decline User:</td>
                                    <td id="TotalDeclineUserCount" style="text-align: center;"></td>
                                </tr>
                            </table>
                        </td>

                    </tr>
                </table>
                <div class="loader"></div>
                <p id="recordCountMessage" class="record-count-message"></p>
            </div>
        </div>
        <div class="clearfix">
        </div>
    </div>
</div>

<script src="~/Scripts/OptInReport/OptInReport.js"></script>

<style>
    .record-count-message {
        font-style: italic;
    }
.loader {
  width: 32px;
  height: 32px;
  position: relative;
  border-radius: 50%;
  color:#659fd5; @*#FF3D00;*@
  animation: fill 1s ease-in infinite alternate;
  margin-left:37%;
  margin-top:5px;
}
.loader::before , .loader::after {
  content: '';
  position: absolute;
  height: 100%;
  width: 100%;
  border-radius: 50%;
  left: 48px;
  top: 0;
  animation: fill 0.9s ease-in infinite alternate;
}

.loader::after {
  left: auto;
  right: 48px;
  animation-duration: 1.1s;
}

@@keyframes fill {
 0% {  box-shadow: 0 0 0 2px inset }
 100%{ box-shadow: 0 0 0 10px inset }
}
</style>
