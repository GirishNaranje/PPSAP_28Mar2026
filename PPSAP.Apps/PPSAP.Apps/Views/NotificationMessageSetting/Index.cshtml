@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="/Scripts/jquery.validate.min.js"></script>
<script src="/Scripts/jquery.validate.unobtrusive.min.js"></script>
<link href="~/Content/admin.css" rel="stylesheet" />
<div id="loadPage"></div>
<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12">
            <ul class="breadcrumb">
                <li class="active">Pop-Up Settings</li>
            </ul>
        </div>
    </div>
</div>
<div class="col-lg-12">
    <div class="content-bg">
        <div class="content-padding relative-position">
            <div class="col-lg-6 col-sm-5 xs-textcenter nopadding">
                <label class="active">Pop-Up Message Settings</label>
            </div>
            <div class="filter-wrapper custom-filter-wrapper">
                <!-- Button trigger modal -->
                <div class="inline-block eq-btn">
                    <a @*href="@Url.Content("~/NotificationMessageSetting/GetMessageSettingForm?id=0")"*@ id="AddNewMsg" class="btn btn-primary marleft10 btn-export" data-toggle="modal">
                        Add New Message
                    </a>
                    <!--<button type="button" id="AddNewMsg" class="btn btn-primary marleft10 btn-export"--> @*onclick="openMessageSettingForm1(0)"*@ <!--data-toggle="modal">
                        Add New Message
                    </button>-->
                </div>
            </div>
            <div class="col-lg-12 nopadding table-responsive" style="margin-top: 20px;">
                <table class="table table-striped" id="NotificationMessageSettingTable">
                    <thead>
                        <tr>
                            <td style="width: 70%;">Message</tdstyle="width:>
                            <td>No Of Time</td>
                            @*<td>Enable</td>*@
                            <td>Action</td>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
                <p id="recordCountMessage" class="record-count-message"></p>
            </div>
        </div>
        <div class="clearfix">
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="MessageSettingModal" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content message-modal-content">
            <div class="modal-header message-modal-header ">
                <button type="button" class="close message-close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Edit Message</h4>
            </div>
            <div id="MessageSettingBody">
            </div>
            <div id="loadingIndicator" class="spinner-border text-primary" role="status" style="display: none;">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/NotificationMessageSetting/NotificationMessageSetting.js"></script>
<style>
    .edit-btn {
        margin-right: 5px; /* Adjust this value to increase/decrease space between edit and delete buttons */
    }
    .record-count-message {
        font-style: italic;
    }
    .table-responsive {
        min-height: 300px;
    }
</style>
