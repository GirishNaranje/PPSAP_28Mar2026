@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";

}
<script>jQuery.noConflict(true);</script>
<script src="~/Scripts/jquery-1.10.2.js"></script>
<script src="~/scripts/DataTables/jquery.dataTables.js"></script>
<link href="~/Content/DataTables/css/buttons.dataTables.min.css" rel="stylesheet" type="text/css" />
<script src="~/scripts/DataTables/dataTables.bootstrap4.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/daterangepicker.js"></script>
<link href="~/Content/admin.css" rel="stylesheet" />


<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12">
            <ul class="breadcrumb">
                <li class="active">Question Performance</li>
            </ul>
        </div>
    </div>
</div>

<div class="col-lg-12">

    <div class="content-bg">
        <div class="content-padding relative-position">
            <div class="col-lg-6 col-md-5 xs-textcenter nopadding">
                <label class="active" style="font-weight: normal;">Show</label>
                <select id="showOptions">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="75">75</option>
                    <option value="100">100</option>
                </select>
                <label class="active" style="font-weight: normal;margin-left:10px;">Page</label>
                <select id="pageOptions">
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="4">5</option>
                    <option value="4">6</option>
                </select>
            </div>
            <div class="col-lg-6 dropdown grey-font font18 pull-right text-right nopadding xs-textcenter">
                <div class="col-lg-6 dropdown grey-font font18 pull-right text-right nopadding xs-textcenter">
                    <div class="inline-block">
                    </div>
                    <div class="inline-block">
                        <input type="button" value="Export" id="Export" class="btn btn-primary marleft10 btn-export">
                    </div>
                </div>
            </div>

            <div class="col-lg-12 nopadding table-responsive" style="margin-top:10px">
                <table class="table table-striped" id="QuestionPerformanceReport">
                    <thead>
                        <tr>
                            <td>Question Title</td>
                            <td>Question Id</td>
                            <td>Section</td>
                            <td>Chapter</td>
                            <td>Topic</td>
                            <td># users answered correctly</td>
                            <td># users answered incorrectly</td>
                            <td># users repeated at least once in SR mode</td>
                            <td>% users answered correctly</td>
                            <td>% users answered incorrectly</td>
                            <td>Correct answer</td>
                            <td>Distractor 1</td>
                            <td># who chose Distractor 1</td>
                            <td>Distractor 2</td>
                            <td># who chose Distractor 2</td>
                            <td>Distractor 3</td>
                            <td># who chose Distractor 3</td>
                            <td>Avg # times incorrect before correct</td>
                            <td># users correct first try</td>
                        </tr>
                    </thead>
                    <tbody id="questionPerformanceTableBody">
                    </tbody>
                    <div class="loader"></div>
                </table>
                <div class="loader"></div>
                <p id="recordCountMessage" class="record-count-message"></p>
            </div>
        </div>
        <div class="clearfix">
        </div>
        @*<div class="text-center paginationclass">
            <nav id="PageNavigation" aria-label="Page navigation example">
                <ul class="pagination margin0">
                    <li id="Firstpage"><a class="page-link" href="#">First</a></li>
                    <li id="Previouspage"><a class="page-link" href="#">Prev</a></li>
                </ul>
            </nav>
        </div>*@
    </div>
</div>

<script src="~/Scripts/AdminQuePerformanceReport/AdminQuePerformanceReport.js"></script>

<style>
    #QuestionPerformanceReport th,
    #QuestionPerformanceReport td {
        white-space: nowrap; /* Prevent wrapping */
        overflow: hidden; /* Hide overflow */
        text-overflow: ellipsis; /* Show ellipsis for overflow */
    }

        #QuestionPerformanceReport th:nth-child(1),
        #QuestionPerformanceReport td:nth-child(1) {
            width: 200px; /* Adjust the width of the first column */
        }

        #QuestionPerformanceReport th:nth-child(2),
        #QuestionPerformanceReport td:nth-child(2) {
            width: 100px; /* Adjust the width of the second column */
        }

    /* Adjust widths for other columns as needed */
    .table-responsive {
        min-height: 300px;
    }
    .record-count-message {
        font-style: italic;
    }
.loader {
  width: 32px;
  height: 32px;
  position: relative;
  border-radius: 50%;
  color:#659fd5; @*#FF3D00;*@
  animation: fill 1s ease-in infinite alternate;
  margin-left:50%;
  margin-top:10px;
}
.loader::before , .loader::after {
  content: '';
  position: absolute;
  height: 100%;
  width: 100%;
  border-radius: 50%;
  left: 48px;
  top: 0;
  animation: fill 0.9s ease-in infinite alternate;
}

.loader::after {
  left: auto;
  right: 48px;
  animation-duration: 1.1s;
}

@@keyframes fill {
 0% {  box-shadow: 0 0 0 2px inset }
 100%{ box-shadow: 0 0 0 10px inset }
}
</style>
